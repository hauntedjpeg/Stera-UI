{
  "name": "stera-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "A component registry for React, built on Base UI and Tailwind CSS.",
  "bin": {
    "stera-ui": "./dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build:cli": "tsc -p cli/tsconfig.json",
    "build:registry": "tsx scripts/build-registry.ts",
    "build:storybook": "storybook build",
    "build": "pnpm build:registry && pnpm build:cli",
    "prepublishOnly": "pnpm build",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.2.0",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "stera-icons": "^8.0.14",
    "storybook": "^8.6.18",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vite": "^6.4.1"
  }
}
