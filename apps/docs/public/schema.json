{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "const": 1
    },
    "css": {
      "type": "string",
      "description": "Path to the global CSS file (relative to project root)."
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": { "type": "string" },
        "utils": { "type": "string" },
        "ui": { "type": "string" },
        "lib": { "type": "string" },
        "hooks": { "type": "string" }
      },
      "required": ["components", "utils", "ui", "lib", "hooks"]
    }
  },
  "required": ["version", "css", "aliases"]
}
