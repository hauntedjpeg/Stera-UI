{
  "name": "stera-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Add Stera UI components to your project.",
  "license": "MIT",
  "author": "Chaz Giese <chazgiese@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hauntedjpeg/Stera-UI.git",
